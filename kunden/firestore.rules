rules_version = '2';

// =====================================================================
// vale-kunden — Firestore Security Rules
//
// Diese Regeln sind die ECHTE Sicherheitsgrenze (nicht roles.js, das ist
// nur UI). In der Firebase-Console unter Firestore Database → Rules
// einfügen und PUBLISH. NICHT aufs Hosting hochladen.
//
// Allowlist MUSS mit js/roles.js übereinstimmen.
// Übergangs-Whitelist MUSS mit js/status.js (kundenFreigabeZiel /
// kundenAenderungZiel) übereinstimmen.
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Identität ---------------------------------------------------
    function istEingeloggt() {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email_verified == true;
    }
    function email() {
      return request.auth.token.email.lower();
    }
    function adminEmails() {
      return ['karlowskivalentin@gmail.com'];
    }
    function kundeEmails() {
      return ['n.berghaus@deussen-immobilien.de', 'c.deussen@deussen-immobilien.de',
              'valentinkolja@icloud.com', 'valentinkolja@gmail.com']; // Test-Zugänge (Valentin) zum Gegenprüfen der Kundenansicht
    }
    function istAdmin() {
      return istEingeloggt() && email() in adminEmails();
    }
    function istKunde() {
      return istEingeloggt() && email() in kundeEmails();
    }
    function istErlaubt() {
      return istAdmin() || istKunde();
    }

    // ---- Kunden-Übergangs-Whitelist (gespiegelt aus status.js) -------
    function erlaubterUebergang(alt, neu) {
      return (alt == '🔍 Freigabe Skript'  && (neu == '🎬 Drehbereit' || neu == '📝 Skript'))
          || (alt == '🔎 Freigabe Schnitt' && (neu == '✅ Freigegeben' || neu == '✂️ Schnitt'));
    }
    // Kunde darf bei Video-Updates NUR diese Felder ändern und nur die
    // 4 erlaubten Status-Übergänge auslösen.
    function kundenVideoUpdateOk() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'freigabeSkript', 'freigabeSchnitt', 'aktualisiertAm'])
          && erlaubterUebergang(resource.data.status, request.resource.data.status);
    }

    // ---- objekte -----------------------------------------------------
    match /objekte/{objektId} {
      allow read: if istErlaubt();
      allow create: if istErlaubt()
                    && request.resource.data.gemeldetVon.lower() == email()
                    && (istAdmin() || request.resource.data.status == 'Eingegangen');
      allow update, delete: if istAdmin();
    }

    // ---- videos ------------------------------------------------------
    match /videos/{videoId} {
      allow read:          if istErlaubt();
      allow create, delete: if istAdmin();
      allow update:        if istAdmin()
                           || (istKunde() && kundenVideoUpdateOk());

      // ---- kommentare (Subcollection) -------------------------------
      match /kommentare/{kommentarId} {
        allow read: if istErlaubt();
        allow create: if istErlaubt()
                      && request.resource.data.autor.lower() == email()
                      && (
                        (istAdmin() && request.resource.data.rolle == 'admin') ||
                        (istKunde() && request.resource.data.rolle == 'kunde')
                      );
        allow update, delete: if false;
      }
    }

    // ---- termine (manuelle Kalender-Einträge) ------------------------
    // Kunde liest nur (read-only Kalender); Admin legt an/ändert/löscht.
    match /termine/{terminId} {
      allow read:               if istErlaubt();
      allow create, update, delete: if istAdmin();
    }

    // ---- plaene (private Video-/Konzept-Planung, Admin-only) ---------
    // Rein interner Planungsbereich („Incognito"). Der Kunde sieht das NIE:
    // weder lesen noch schreiben. Auch ein „veröffentlichter" Plan bleibt
    // hier — er wird nur vom Admin am Bildschirm als Referenz präsentiert.
    match /plaene/{planId} {
      allow read, write: if istAdmin();
    }

    // ---- shotvorlagen (wiederverwendbare Shot-Vorlagen, Admin-only) --
    // Globale Bibliothek einzelner Shot-Textzeilen, die der Admin in die
    // Shotlist eines Plans kopieren kann. Der Kunde sieht das NIE.
    match /shotvorlagen/{vorlageId} {
      allow read, write: if istAdmin();
    }

    // ---- gedanken (persönliche Mindmap, Admin-only) -----------------
    // Rein private Denk-/Ideen-Leinwand. Der Kunde sieht das NIE — weder
    // lesen noch schreiben. Gleiche Vertrauensgrenze wie plaene/shotvorlagen.
    match /gedanken/{gedankeId} {
      allow read, write: if istAdmin();
    }

    // ---- dateiblobs (Base64-Anhänge der Gedanken, Admin-only) --------
    // Die eigentlichen Datei-Bytes eines Gedanken-Anhangs. On-demand geladen.
    match /dateiblobs/{blobId} {
      allow read, write: if istAdmin();
    }

    // ---- fokusvideos (kuratierte Fokus-YouTube-Liste, Admin-only) ----
    // Private Anspiel-Liste auf der Fokus-Seite. Nur Metadaten (kein Blob).
    // Gleiche Vertrauensgrenze wie gedanken/plaene/shotvorlagen.
    match /fokusvideos/{id} {
      allow read, write: if istAdmin();
    }

    // ---- fokussessions (Verlauf der Fokus-Sessions, Admin-only) ------
    // Ein Doc = eine abgeschlossene Session (Name/Dauer/Start/Ende).
    match /fokussessions/{id} {
      allow read, write: if istAdmin();
    }

    // ---- mindmaps (benannte Gedanken-Leinwände, Admin-only) ---------
    // Ein Doc = eine zusätzliche Mindmap (Gedanken tragen mapId).
    match /mindmaps/{id} {
      allow read, write: if istAdmin();
    }

    // ---- Alles andere: zu ------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
