rules_version = '2';

// =====================================================================
// vale-kunden — Firestore Security Rules
//
// Diese Regeln sind die ECHTE Sicherheitsgrenze (nicht roles.js, das ist
// nur UI). In der Firebase-Console unter Firestore Database → Rules
// einfügen und PUBLISH. NICHT aufs Hosting hochladen.
//
// Allowlist MUSS mit js/roles.js übereinstimmen.
// Übergangs-Whitelist MUSS mit js/status.js (kundenFreigabeZiel /
// kundenAenderungZiel) übereinstimmen.
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Identität ---------------------------------------------------
    function istEingeloggt() {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email_verified == true;
    }
    function email() {
      return request.auth.token.email.lower();
    }
    function adminEmails() {
      return ['karlowskivalentin@gmail.com'];
    }
    function kundeEmails() {
      return ['n.berghaus@deussen-immobilien.de', 'c.deussen@deussen-immobilien.de',
              'valentinkolja@icloud.com', 'valentinkolja@gmail.com']; // Test-Zugänge (Valentin) zum Gegenprüfen der Kundenansicht
    }
    function istAdmin() {
      return istEingeloggt() && email() in adminEmails();
    }
    function istKunde() {
      return istEingeloggt() && email() in kundeEmails();
    }
    function istErlaubt() {
      return istAdmin() || istKunde();
    }

    // ---- Kollaborator (geteilte Map-Bearbeitung per Einmal-Code) ------
    // Wer ein Freischaltungs-Dokument kollaboratoren/<email> hat, darf GENAU
    // die dort hinterlegte Mindmap lesen/bearbeiten — sonst nichts.
    function istKollaborator() {
      return istEingeloggt()
          && exists(/databases/$(database)/documents/kollaboratoren/$(email()));
    }
    function kollaboratorMap() {
      return get(/databases/$(database)/documents/kollaboratoren/$(email())).data.mapId;
    }

    // ---- Map-Mitgliedschaft (geteilte + selbst angelegte Mindmaps) ----
    // Eine Map kennt ihre Nutzer über data.mitglieder. Wer Mitglied ist,
    // darf die Map und ihre Gedanken lesen/bearbeiten.
    function istMapMitglied(mapId) {
      return istEingeloggt()
          && exists(/databases/$(database)/documents/mindmaps/$(mapId))
          && email() in get(/databases/$(database)/documents/mindmaps/$(mapId)).data.get('mitglieder', []);
    }
    function darfAufMap(mapId) {
      return istAdmin()
          || (istKollaborator() && mapId == kollaboratorMap())
          || istMapMitglied(mapId);
    }

    // ---- Kunden-Übergangs-Whitelist (gespiegelt aus status.js) -------
    function erlaubterUebergang(alt, neu) {
      return (alt == '🔍 Freigabe Skript'  && (neu == '🎬 Drehbereit' || neu == '📝 Skript'))
          || (alt == '🔎 Freigabe Schnitt' && (neu == '✅ Freigegeben' || neu == '✂️ Schnitt'));
    }
    // Kunde darf bei Video-Updates NUR diese Felder ändern und nur die
    // 4 erlaubten Status-Übergänge auslösen.
    function kundenVideoUpdateOk() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'freigabeSkript', 'freigabeSchnitt', 'aktualisiertAm'])
          && erlaubterUebergang(resource.data.status, request.resource.data.status);
    }

    // ---- objekte -----------------------------------------------------
    match /objekte/{objektId} {
      allow read: if istErlaubt();
      allow create: if istErlaubt()
                    && request.resource.data.gemeldetVon.lower() == email()
                    && (istAdmin() || request.resource.data.status == 'Eingegangen');
      allow update, delete: if istAdmin();
    }

    // ---- videos ------------------------------------------------------
    match /videos/{videoId} {
      allow read:          if istErlaubt();
      allow create, delete: if istAdmin();
      allow update:        if istAdmin()
                           || (istKunde() && kundenVideoUpdateOk());

      // ---- kommentare (Subcollection) -------------------------------
      match /kommentare/{kommentarId} {
        allow read: if istErlaubt();
        allow create: if istErlaubt()
                      && request.resource.data.autor.lower() == email()
                      && (
                        (istAdmin() && request.resource.data.rolle == 'admin') ||
                        (istKunde() && request.resource.data.rolle == 'kunde')
                      );
        allow update, delete: if false;
      }
    }

    // ---- termine (manuelle Kalender-Einträge) ------------------------
    // Kunde liest nur (read-only Kalender); Admin legt an/ändert/löscht.
    match /termine/{terminId} {
      allow read:               if istErlaubt();
      allow create, update, delete: if istAdmin();
    }

    // ---- plaene (private Video-/Konzept-Planung, Admin-only) ---------
    // Rein interner Planungsbereich („Incognito"). Der Kunde sieht das NIE:
    // weder lesen noch schreiben. Auch ein „veröffentlichter" Plan bleibt
    // hier — er wird nur vom Admin am Bildschirm als Referenz präsentiert.
    match /plaene/{planId} {
      allow read, write: if istAdmin();
    }

    // ---- shotvorlagen (wiederverwendbare Shot-Vorlagen, Admin-only) --
    // Globale Bibliothek einzelner Shot-Textzeilen, die der Admin in die
    // Shotlist eines Plans kopieren kann. Der Kunde sieht das NIE.
    match /shotvorlagen/{vorlageId} {
      allow read, write: if istAdmin();
    }

    // ---- gedanken (persönliche Mindmap, Admin-only) -----------------
    // Rein private Denk-/Ideen-Leinwand. Der Kunde sieht das NIE — weder
    // lesen noch schreiben. Gleiche Vertrauensgrenze wie plaene/shotvorlagen.
    match /gedanken/{gedankeId} {
      allow read:   if istAdmin() || darfAufMap(resource.data.get('mapId', 'default'));
      allow create: if darfAufMap(request.resource.data.get('mapId', 'default'));
      // Nicht-Admins dürfen die mapId eines Gedankens nicht ändern
      // (kein Verschieben in fremde/aus geteilten Maps).
      allow update: if istAdmin()
                    || (darfAufMap(resource.data.get('mapId', 'default'))
                        && request.resource.data.get('mapId', 'default') == resource.data.get('mapId', 'default'));
      allow delete: if istAdmin() || darfAufMap(resource.data.get('mapId', 'default'));
    }

    // ---- dateiblobs (Base64-Anhänge der Gedanken) -------------------
    // Admin: alles. Kollaborator: einzelne Blobs lesen (get) + neue anlegen —
    // aber NICHT auflisten (list) und keine fremden ändern/löschen.
    match /dateiblobs/{blobId} {
      allow get:    if istAdmin() || istKollaborator();
      allow list:   if istAdmin();
      allow create: if istAdmin() || istKollaborator();
      allow update, delete: if istAdmin();
    }

    // ---- inspirationen (Inspirations-Dashboard, Admin-only) ----------
    // Cards mit Kategorie (profil|video|sonstiges), Referenz-Link (Video/
    // Account) und eigenen davon inspirierten Videos. Der Kunde sieht das NIE.
    match /inspirationen/{id} {
      allow read, write: if istAdmin();
    }

    // ---- fokusvideos (kuratierte Fokus-YouTube-Liste, Admin-only) ----
    // Private Anspiel-Liste auf der Fokus-Seite. Nur Metadaten (kein Blob).
    // Gleiche Vertrauensgrenze wie gedanken/plaene/shotvorlagen.
    match /fokusvideos/{id} {
      allow read, write: if istAdmin();
    }

    // ---- fokussessions (Verlauf der Fokus-Sessions, Admin-only) ------
    // Ein Doc = eine abgeschlossene Session (Name/Dauer/Start/Ende).
    match /fokussessions/{id} {
      allow read, write: if istAdmin();
    }

    // ---- mindmaps (benannte Gedanken-Leinwände) --------------------
    // Ein Doc = eine Mindmap { name, besitzer, mitglieder[] }. Admin
    // verwaltet alle. Kollaboratoren: sehen ihre Mitglieds-Maps + die per
    // Einladung geteilte; legen NUR eigene Maps an (sie selbst Besitzer und
    // einziges Mitglied); löschen nur eigene.
    match /mindmaps/{id} {
      allow get:   if istAdmin()
                   || (istEingeloggt() && email() in resource.data.get('mitglieder', []))
                   || (istKollaborator() && id == kollaboratorMap());
      allow list:  if istAdmin()
                   || (istEingeloggt() && email() in resource.data.get('mitglieder', []));
      allow create: if istAdmin()
                    || (istKollaborator()
                        && request.resource.data.get('besitzer', '') == email()
                        && request.resource.data.get('mitglieder', []) == [email()]);
      // Ändern: Admin frei. Außerdem darf sich ein Nutzer beim Einlösen seiner
      // Einladung selbst als Mitglied ergänzen (atomarer Batch, getAfter prüft
      // die frisch angelegte Freischaltung; bestehende Mitglieder bleiben).
      allow update: if istAdmin()
                    || (istEingeloggt()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mitglieder'])
                        && request.resource.data.get('mitglieder', []).hasAll(resource.data.get('mitglieder', []))
                        && email() in request.resource.data.get('mitglieder', [])
                        && getAfter(/databases/$(database)/documents/kollaboratoren/$(email())).data.mapId == id);
      allow delete: if istAdmin()
                    || (istEingeloggt() && resource.data.get('besitzer', '') == email());
    }

    // ---- benachrichtigungen (Glocke: anerkannt/kommentiert) ---------
    // Ein Doc = eine Nachricht an data.fuer. Lesen/als-gelesen-markieren
    // darf nur der Empfänger; anlegen jeder legitime Nutzer im eigenen Namen.
    match /benachrichtigungen/{id} {
      allow read:   if istAdmin() || (istEingeloggt() && resource.data.fuer == email());
      allow create: if (istErlaubt() || istKollaborator())
                    && request.resource.data.von == email()
                    && request.resource.data.fuer is string;
      allow update: if istAdmin()
                    || (istEingeloggt() && resource.data.fuer == email()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['gelesen']));
      allow delete: if istAdmin() || (istEingeloggt() && resource.data.fuer == email());
    }

    // ---- kollaboratoren (Freischaltung: E-Mail → eine Map) ---------
    // Ein Doc kollaboratoren/<email> = Zugriff auf data.mapId. Anlegen darf
    // sich ein Nutzer NUR SELBST, und nur wenn im selben Batch der zugehörige
    // Einladungscode (einladung/<mapId>) auf ihn eingelöst wird (getAfter).
    match /kollaboratoren/{kEmail} {
      allow get:    if istAdmin() || (istEingeloggt() && kEmail == email());
      allow list:   if istAdmin();
      allow create: if istEingeloggt()
                    && kEmail == email()
                    && request.resource.data.mapId is string
                    && getAfter(/databases/$(database)/documents/einladung/$(request.resource.data.mapId)).data.eingeloestVon == email();
      allow update, delete: if istAdmin();
    }

    // ---- einladung (Einmal-Codes) ----------------------------------
    // { code, mapId, eingeloestVon }. Der Code ist NICHT lesbar (nur Admin),
    // damit er nicht ausgespäht werden kann. Einlösen = eingeloestVon von null
    // auf die eigene E-Mail setzen UND den korrekten Code mitsenden (die Rule
    // prüft ihn gegen den gespeicherten). Danach ist der Code verbraucht.
    match /einladung/{id} {
      allow get, list: if istAdmin();
      allow create, delete: if istAdmin();
      allow update: if istAdmin()
                    || (istEingeloggt()
                        && resource.data.eingeloestVon == null
                        && request.resource.data.eingeloestVon == email()
                        && request.resource.data.code == resource.data.code
                        && request.resource.data.mapId == resource.data.mapId
                        && request.resource.data.keys().hasOnly(['code', 'mapId', 'eingeloestVon']));
    }

    // ---- Alles andere: zu ------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
