# Zeilenenden konsistent halten (Cross-Platform: Mac + Windows auf exFAT-SSD).
# Alles textuelle wird im Repo als LF gespeichert; Git erkennt Binaries automatisch.
* text=auto eol=lf

# Explizite LF-Regeln fuer Skripte/Code (bleiben auf dem Mac ausfuehrbar)
*.sh    text eol=lf
*.py    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.md    text eol=lf

# Windows-spezifische Skripte brauchen CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binaries nicht anfassen
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.mp4   binary
*.mov   binary
